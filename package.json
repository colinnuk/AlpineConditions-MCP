{
  "name": "alpineconditions-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for alpineconditions.com mountain weather and geolocation tools",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:mcpb": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-mcpb.ps1",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:prod": "node --import tsx --test test/prod/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
